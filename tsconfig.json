{
	"compilerOptions": {
		"target": "ES2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["node"]
	},
	"include": ["src/**/*", "cli/**/*", "benchmark/**/*"],
	"exclude": ["fixtures/**", "node_modules", "dist"]
}
